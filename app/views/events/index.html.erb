<%= turbo_frame_tag 'events' do %>
  <%# Header %>
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-3xl font-bold">Events</h1>
    <% if user_signed_in? %>
      <%= link_to "Log Out", destroy_user_session_path, class: 'text-blue-400 hover:underline' %>
    <% else %>
      <%= link_to "Log In", new_user_session_path, data: { turbo_frame: "_top" }, class: 'text-blue-400 hover:underline' %>
    <% end %>
  </div>

  <nav class="mb-6">
    <ul class="flex space-x-4 text-blue-400">
      <li><%= link_to "Events", events_path, class: "hover:underline" %></li>
      <% if user_signed_in? %>
        <li><%= link_to "New Event", new_event_path, data: { turbo_frame: "_top" }, class: "hover:underline" %></li>
      <% end %>
    </ul>
  </nav>

  <div class="grid grid-cols-2 gap-4">
    <% @events.each do |event| %>
      <div class="bg-gray-800 p-4 rounded-lg">
        <h2 class="text-2xl font-bold mb-2"><%= event.title %></h2>
        <p class="text-gray-300 mb-1"><%= event.description %></p>
        <p class="text-gray-400 text-sm mb-4"><%= event.date %></p>
        <div>
          <%= link_to 'View Details', event_path(event), data: { turbo_frame: "_top" }, class: 'text-blue-400 hover:underline' %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

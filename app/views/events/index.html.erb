<%= turbo_frame_tag 'events' do %>
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-3xl font-bold">Events</h1>
    <% if user_signed_in? %>
      <%= link_to "Log Out", destroy_user_session_path, data: { turbo_method: :delete }, class: 'text-blue-400 hover:underline' %>
    <% else %>
      <%= link_to "Log In", new_user_session_path, data: { turbo_frame: "_top" }, class: 'text-blue-400 hover:underline' %>
    <% end %>
  </div>

  <nav class="mb-6">
    <ul class="flex space-x-4 text-blue-400">
      <li><%= link_to "Events", events_path, class: "hover:underline" %></li>
      <% if user_signed_in? %>
        <li><%= link_to "New Event", new_event_path, data: { turbo_frame: "_top" }, class: "hover:underline" %></li>
      <% end %>
    </ul>
  </nav>

  <h2 class="text-xl font-semibold mb-3">Upcoming Events</h2>
  <% if @upcoming_events.any? %>
    <div class="grid grid-cols-2 gap-4 mb-8">
      <% @upcoming_events.each do |event| %>
        <div class="bg-gray-800 p-4 rounded-lg">
          <h3 class="text-lg font-bold mb-1"><%= event.title %></h3>
          <p class="text-gray-300 text-sm mb-1"><%= event.description %></p>
          <p class="text-gray-400 text-sm mb-4"><%= event.date.strftime("%B %-d, %Y") %></p>
          <%= link_to "View Details", event_path(event), data: { turbo_frame: "_top" }, class: "text-blue-400 hover:underline text-sm" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500 mb-8">No upcoming events.</p>
  <% end %>

  <h2 class="text-xl font-semibold mb-3 text-gray-400">Past Events</h2>
  <% if @past_events.any? %>
    <div class="grid grid-cols-2 gap-4">
      <% @past_events.each do |event| %>
        <div class="bg-gray-800/50 p-4 rounded-lg">
          <h3 class="text-lg font-bold mb-1 text-gray-300"><%= event.title %></h3>
          <p class="text-gray-400 text-sm mb-1"><%= event.description %></p>
          <p class="text-gray-500 text-sm mb-4"><%= event.date.strftime("%B %-d, %Y") %></p>
          <%= link_to "View Details", event_path(event), data: { turbo_frame: "_top" }, class: "text-blue-400/70 hover:underline text-sm" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500">No past events.</p>
  <% end %>
<% end %>

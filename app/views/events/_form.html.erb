<div class="bg-gray-800 rounded-xl p-6 max-w-lg">
  <%= form_with(model: @event, local: true) do |form| %>
    <div class="mb-4">
      <%= form.label :title, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= form.text_field :title, class: "w-full bg-gray-700 text-white border border-gray-600 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <div class="mb-4">
      <%= form.label :description, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= form.text_area :description, rows: 4, class: "w-full bg-gray-700 text-white border border-gray-600 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <div class="mb-4">
      <%= form.label :date, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= form.date_field :date, class: "w-full bg-gray-700 text-white border border-gray-600 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      <%= form.label :time, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= form.time_field :time, class: "w-full bg-gray-700 text-white border border-gray-600 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <div class="mb-6">
      <%= form.label :location, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= form.text_field :location, class: "w-full bg-gray-700 text-white border border-gray-600 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <div class="mb-6">
      <%= form.label :is_public, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= form.check_box :is_public, class: "w-full bg-gray-700 text-white border border-gray-600 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <div>
      <%= form.submit class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>

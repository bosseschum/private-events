<div class="bg-gray-950 rounded-xl p-6 max-w-lg">
    <%= form_with(model: @event, local: true) do |form| %>
        <div class="mb-4">
            <%= form.label :title %>
            <%= form.text_field :title %>
        </div>
        <div class="mb-4">
            <%= form.label :description %>
            <%= form.text_area :description %>
        </div>
        <div class="mb-4">
            <%= form.label :date %>
            <%= form.date_field :date %>
        </div>
        <div class="mb-4">
            <%= form.label :location %>
            <%= form.text_field :location %>
        </div>
        <div class="mb-4">
            <%= form.submit "Create Event" %>
        </div>
    <% end %>
</div>
